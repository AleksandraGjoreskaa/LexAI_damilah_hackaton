# Application Settings
APP_NAME=LexAI
DEBUG=True

# Database
DATABASE_URL=sqlite+aiosqlite:///./lexai.db

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_data

# Embedding Model (multilingual-e5-base supports Macedonian well)
EMBEDDING_MODEL=intfloat/multilingual-e5-base

# PDF Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# Chunking Settings
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# LLM - Gemini
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-2.0-flash
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048
